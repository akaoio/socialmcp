# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Shared secret used to derive the ZEN keypair for the bridge relay.
# Must match the value set in the Chrome extension's Options page.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SOCIALMCP_SECRET=change-me-to-a-strong-random-value

# Port the ZEN relay listens on (default: 8420)
# SOCIALMCP_PORT=8420
