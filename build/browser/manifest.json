{
  "manifest_version": 3,
  "name": "Social MCP",
  "version": "1.0.0",
  "description": "MCP bridge for social media automation",

  "permissions": [
    "tabs",
    "alarms",
    "scripting",
    "storage"
  ],

  "action": {
    "default_title": "Social MCP",
    "default_popup": "popup.html"
  },

  "host_permissions": [
    "ws://127.0.0.1/*",
    "http://127.0.0.1/*",
    "https://www.facebook.com/*",
    "https://x.com/*",
    "https://www.instagram.com/*",
    "https://www.threads.net/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["facebook/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["x/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["instagram/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.threads.net/*"],
      "js": ["threads/content.js"],
      "run_at": "document_idle"
    }
  ]
}
